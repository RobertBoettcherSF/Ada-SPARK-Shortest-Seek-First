-- GPR file for the SSTF Test Runner
-- This project file compiles and runs the test suite

project Test_Runner is
   for Source_Dirs use ("..\src", ".");
   for Object_Dir use "../obj/test";
   for Exec_Dir use "../bin";

   for Main use ("test_runner.adb");

   package Compiler is
      -- Enable Ada 2012 features, assertions, overflow checks, and all warnings
      for Default_Switches ("Ada") use ("-gnat2012", "-gnata", "-gnato", "-gnatwa");
   end Compiler;

   package Linker is
      -- Link with necessary libraries
      for Default_Switches ("Ada") use ("-static");
   end Linker;

end Test_Runner;
